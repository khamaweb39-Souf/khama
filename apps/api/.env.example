# ════════════════════════════════════════
# Khama API - Environment Variables
# ════════════════════════════════════════
# انسخ هذا الملف إلى .env وعدّل القيم

# ─── قاعدة البيانات ───────────────────
# للتطوير المحلي (PostgreSQL):
DATABASE_URL="postgresql://postgres:password@localhost:5432/khama?schema=public"
# لـ Render Free Tier - يُضاف تلقائياً من render.yaml
# DATABASE_URL="postgres://khama_user:xxxxx@dpg-xxx.oregon-postgres.render.com/khama"

# ─── JWT ──────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="30d"

# ─── Cloudinary (للصور) ───────────────
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── البيئة ───────────────────────────
NODE_ENV="development"
PORT=3005

# ─── CORS ─────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8081"
